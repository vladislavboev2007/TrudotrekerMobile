<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LaborTracker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:LaborTracker.Views"
    FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">

    <!-- ОСНОВНЫЕ ВКЛАДКИ -->
    <TabBar>
        <!-- Главная -->
        <Tab Title="Главная" Icon="home_icon.png">
            <ShellContent 
                Route="MainPage"
                ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>

        <!-- Задачи -->
        <Tab Title="Задачи" Icon="tasks_black.png">
            <ShellContent 
                Route="TasksPage"
                ContentTemplate="{DataTemplate views:TasksPage}" />
        </Tab>

        <!-- Сотрудники -->
        <Tab Title="Сотрудники" Icon="users_black.png">
            <ShellContent 
                Route="EmployeesPage"
                ContentTemplate="{DataTemplate views:EmployeesPage}" />
        </Tab>
    </TabBar>

    <!-- ДОПОЛНИТЕЛЬНЫЕ МАРШРУТЫ (не вкладки) -->
    <ShellContent
        Route="AddTaskPage"
        ContentTemplate="{DataTemplate views:AddTaskPage}" />

</Shell>