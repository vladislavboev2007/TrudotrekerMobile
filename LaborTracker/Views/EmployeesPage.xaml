<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:LaborTracker.Models"
             xmlns:viewmodels="clr-namespace:LaborTracker.ViewModels"
             x:Class="LaborTracker.Views.EmployeesPage"
             x:DataType="viewmodels:EmployeesViewModel">

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- Заголовок в 0-row -->
        <Label Grid.Row="0"
               Text="Сотрудники"
               FontFamily="Montserrat-Bold"
               FontSize="24"
               TextColor="{AppThemeBinding Light=Black, Dark=White}"
               Padding="20,20,20,10"
               VerticalOptions="Center"
               HorizontalOptions="Center" />

        <!-- Кнопка в 1-row (под заголовком, справа) -->
        <Button Grid.Row="1"
                Text="Добавить"
                FontFamily="Montserrat-Medium"
                CornerRadius="10"
                BackgroundColor="#4CAF50"
                TextColor="White"
                HeightRequest="40"
                WidthRequest="100"
                HorizontalOptions="End"
                Margin="0,0,20,10"
                Command="{Binding AddEmployeeCommand}" />

        <!-- Список сотрудников в 2-row -->
        <RefreshView Grid.Row="2" 
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">

            <CollectionView ItemsSource="{Binding Employees}"
                           SelectionMode="None">

                <CollectionView.EmptyView>
                    <Border Stroke="LightGray"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="White"
                            Padding="20"
                            Margin="20">
                        <VerticalStackLayout HorizontalOptions="Center" 
                                             VerticalOptions="Center"
                                             Spacing="20">
                            <Image Source="users_black.png"
                                   WidthRequest="80"
                                   HeightRequest="80"
                                   Opacity="0.3" />
                            <Label Text="Сотрудники не найдены"
                                   FontFamily="Montserrat"
                                   FontSize="16"
                                   TextColor="Gray" />
                            <Button Text="Добавить первого сотрудника"
                                    Command="{Binding AddEmployeeCommand}"
                                    BackgroundColor="#4CAF50"
                                    TextColor="White"
                                    HeightRequest="40"
                                    WidthRequest="200" />
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Employee">
                        <Border Stroke="LightGray"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="White"
                                Padding="15"
                                Margin="20,5">

                            <Grid ColumnDefinitions="Auto, *, Auto"
                                  RowDefinitions="Auto, Auto">


                                <!-- ФИО сотрудника -->
                                <Label Grid.Column="1" Grid.Row="0"
                                       Text="{Binding FIO}"
                                       FontFamily="Montserrat-Medium"
                                       FontSize="16"
                                       TextColor="Black"
                                       VerticalOptions="Center"
                                       Margin="10,0,0,0" />

                                <!-- ID сотрудника -->
                                <Label Grid.Column="1" Grid.Row="1"
                                       Text="{Binding EmpId, StringFormat='ID: {0}'}"
                                       FontFamily="Montserrat"
                                       FontSize="12"
                                       TextColor="Gray"
                                       Margin="10,5,0,0" />

                                <!-- Кнопка удаления -->
                                <ImageButton Grid.Column="2" Grid.RowSpan="2"
                                             Source="delete_icon.png"
                                             BackgroundColor="Transparent"
                                             HeightRequest="30"
                                             WidthRequest="30"
                                             HorizontalOptions="End"
                                             VerticalOptions="Center"
                                             Command="{Binding BindingContext.DeleteEmployeeCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                             CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>

</ContentPage>